# Exclude development and test files from production deployments

# Dev scripts
api/scripts/
scripts/
dev-tools/

# Test folders and files
**/__tests__/
**/tests/
**/*.spec.*
**/*.test.*
**/*_spec.*

# Mocks and local configs
**/*.mock.*
**/*.local

# Environment files (do not deploy secrets)
*.env
*.env.*
api/.env*
mobile/.env*

# Editor/IDE
.vscode/
.idea/

# GitHub workflows and config not needed for runtime
.github/
