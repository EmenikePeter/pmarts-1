# PMARTS API Environment Template
# Copy to .env and fill with real values in your deployment platform.
# Never commit real secrets.

# Runtime
NODE_ENV=development
PORT=4000
REQUEST_BODY_LIMIT=10mb
LOG_LEVEL=info

# Supabase (server-side)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_EVIDENCE_BUCKET=evidence

# Pi Network API Configuration
# Get API keys from https://developers.minepi.com/
PI_ENV=testnet
PI_TESTNET_API_URL=https://api.testnet.minepi.com
PI_TESTNET_API_KEY=YOUR_PI_TESTNET_API_KEY
PI_MAINNET_API_URL=https://api.minepi.com
PI_MAINNET_API_KEY=YOUR_PI_MAINNET_API_KEY

# Security controls (keep false in shared/staging/prod unless intentionally debugging)
ALLOW_DEV_AUTH_BYPASS=false
ENABLE_DEBUG_ROUTES=false
ENABLE_DEBUG_TOKEN_ROUTE=false
STRICT_PI_SESSION_VERIFY=true
FAIL_ON_MISSING_PI=false

# Optional integrations
# PAYMENT_WEBHOOK_SECRET is needed only if you accept signed payment webhooks.
# DELIVERY_CODE_SECRET is required when delivery-code / QR completion is enabled.
# DELIVERY_QR_MAX_AGE_SECONDS controls QR replay window (default 300 seconds).
PAYMENT_WEBHOOK_SECRET=YOUR_PAYMENT_WEBHOOK_SECRET
DELIVERY_CODE_SECRET=YOUR_DELIVERY_CODE_SECRET
DELIVERY_QR_MAX_AGE_SECONDS=300
MAGIC_LINK_REDIRECT=http://localhost:3000

# Optional worker settings
PUSH_WORKER_PORT=4100
PUSH_WORKER_INTERVAL_MS=30000

# Optional frontend routing hints used by some API responses
EXPO_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
